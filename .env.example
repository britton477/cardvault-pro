# =============================================================================
# CardVault Pro — Environment variable reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cardvault-images
R2_PUBLIC_URL=https://images.yourdomain.com

# ── eBay encryption ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Once eBay credentials are stored, do NOT change this key.
# Changing it makes all stored credentials unreadable. See KEY_ROTATION.md.
EBAY_ENCRYPTION_KEY=your-64-char-hex-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret from dashboard.stripe.com → Developers → Webhooks
# Point the endpoint at: https://yourdomain.com/api/billing/webhook
# Subscribe to: checkout.session.completed, customer.subscription.created/updated/deleted,
#               invoice.payment_failed, invoice.payment_succeeded
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your three subscription products (monthly, GBP)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Sentry ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# CI/CD only (not needed locally):
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=cardvault-pro

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
