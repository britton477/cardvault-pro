# =============================================================================
# CardVault Pro — .gitignore
# CRITICAL: .env.local must NEVER be committed to git.
# All secrets live in Vercel environment variables in production.
# =============================================================================

# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production

# ── Next.js build output ──────────────────────────────────────────────────────
.next/
out/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Supabase local dev ────────────────────────────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Sentry ────────────────────────────────────────────────────────────────────
.sentryclirc

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json
.idea/

# ── Sharp native binaries (rebuilt on each platform during install) ───────────
# node_modules already excluded above — this is belt-and-braces
vendor/

# ── Test / coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
.turbo/

# ── Local admin scripts (never commit) ────────────────────────────────────────
*.bat
